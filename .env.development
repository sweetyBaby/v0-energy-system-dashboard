# 开发环境
# API_BASE_URL=http://10.10.99.207:8080/
# API_BASE_URL=http://10.10.99.152:8080/
# 本地开发如果走公司外网 Nginx，需要指向真实后端代理入口 /prod-api，而不是前端地址 /api
API_BASE_URL=http://223.107.76.50:9016/prod-api
NEXT_PUBLIC_ENABLE_AUTH_HEADER=true

# 报表中心(日报)接口的上游，独立于通用 API（9016/prod-api）。
# 日报接口与报表/日志文件下载都经服务端代理 /api/report-proxy/* 转发到这里。
REPORT_API_BASE_URL=http://223.107.76.50:8083
